--- a/src/targets/gpu/CMakeLists.txt
+++ b/src/targets/gpu/CMakeLists.txt
@@ -252,15 +252,31 @@ rocm_clang_tidy_check(migraphx_gpu)
 
 set(MIGRAPHX_ENABLE_MLIR ON CACHE BOOL "")
 
 if(MIGRAPHX_ENABLE_MLIR)
-    # Find package rocMLIR
-    find_package(rocMLIR 1.0.0 CONFIG REQUIRED)
-    message(STATUS "Build with rocMLIR::rockCompiler ${rocMLIR_VERSION}")
-    target_compile_definitions(migraphx_gpu PRIVATE "-DMIGRAPHX_MLIR")
-    # Make this private to avoid multiple inclusions of LLVM symbols.
-    target_link_libraries(migraphx_gpu PRIVATE rocMLIR::rockCompiler)
-    # Hide LLVM internals that come from rocMLIR.
-    if(NOT WIN32 AND NOT APPLE AND BUILD_SHARED_LIBS)
-        target_link_options(migraphx_gpu PRIVATE "LINKER:--exclude-libs,ALL")
-    endif()
+    # Find rocMLIR libraries directly without CMake config.
+    find_library(ROCMLIR_LIBRARY
+        NAMES rockCompiler librockCompiler
+        PATHS ${CMAKE_PREFIX_PATH}
+        PATH_SUFFIXES lib lib64
+        NO_DEFAULT_PATH
+    )
+
+    if(ROCMLIR_LIBRARY)
+        message(STATUS "Found rocMLIR library: ${ROCMLIR_LIBRARY}")
+        add_library(rocMLIR::rockCompiler SHARED IMPORTED)
+        set_target_properties(rocMLIR::rockCompiler PROPERTIES
+            IMPORTED_LOCATION "${ROCMLIR_LIBRARY}"
+        )
+        target_compile_definitions(migraphx_gpu PRIVATE "-DMIGRAPHX_MLIR")
+        # Make this private to avoid multiple inclusions of LLVM symbols.
+        target_link_libraries(migraphx_gpu PRIVATE rocMLIR::rockCompiler)
+        message(STATUS "Build with rocMLIR support enabled")
+        # Hide LLVM internals that come from rocMLIR.
+        if(NOT WIN32 AND NOT APPLE AND BUILD_SHARED_LIBS)
+            target_link_options(migraphx_gpu PRIVATE "LINKER:--exclude-libs,ALL")
+        endif()
+    else()
+        message(FATAL_ERROR "MIGRAPHX_ENABLE_MLIR is enabled, but rocMLIR::rockCompiler could not be found in CMAKE_PREFIX_PATH=${CMAKE_PREFIX_PATH}")
+    endif()
 endif()

