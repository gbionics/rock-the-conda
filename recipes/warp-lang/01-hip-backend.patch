+#define nvrtcGetErrorString            hiprtcGetErrorString
+#define nvrtcVersion                   hiprtcVersion
+#define nvrtcCreateProgram             hiprtcCreateProgram
+#define nvrtcDestroyProgram            hiprtcDestroyProgram
