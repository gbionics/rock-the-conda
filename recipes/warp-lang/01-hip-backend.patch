 #define cudaGraphUpload               hipGraphUpload
@@ -194,6 +197,29 @@ typedef size_t (*CUoccupancyB2DSize)(int);
 
 #define cudaErrorCallRequiresNewerDriver hipErrorNotSupported
 
+// NVRTC-to-hipRTC compatibility
